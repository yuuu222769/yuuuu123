generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// User
// ============================================
model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  displayName   String?   @map("display_name")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  settings          UserSetting?
  projects          Project[]
  knowledgeEntries  KnowledgeEntry[]
  workspaceMembers  WorkspaceMember[]
  ownedWorkspaces   Workspace[]       @relation("OwnedWorkspaces")
  aiUsageLogs       AIUsageLog[]

  @@map("users")
}

// ============================================
// User settings (AI keys, preferences)
// ============================================
model UserSetting {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  apiKey       String?  @map("api_key")
  apiBase      String?  @map("api_base") @default("https://api.openai.com/v1")
  modelName    String?  @map("model_name") @default("gpt-4o")
  defaultStyle String?  @map("default_style")
  defaultType  String?  @map("default_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ============================================
// Workspace — tenant / team container
// ============================================
model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  ownerId   String   @map("owner_id") @db.Uuid
  planTier  String   @default("free") @map("plan_tier") // free | pro | team | enterprise
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner        User               @relation("OwnedWorkspaces", fields: [ownerId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  projects     Project[]
  subscription Subscription?

  @@map("workspaces")
}

// ============================================
// Workspace member — role-based access
// ============================================
model WorkspaceMember {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("member") // owner | admin | member
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ============================================
// Project
// ============================================
model Project {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  workspaceId    String?  @map("workspace_id") @db.Uuid
  name           String
  contentType    String   @default("other") @map("content_type")
  platform       String?  @default("douyin")
  targetAudience String?  @map("target_audience")
  duration       String?  @default("60s")
  style          String?
  description    String?
  status         String   @default("draft")
  visibility     String   @default("workspace") // private | workspace
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  knowledgeEntries  KnowledgeEntry[]
  aiUsageLogs       AIUsageLog[]

  @@index([userId])
  @@index([workspaceId])
  @@index([updatedAt(sort: Desc)])
  @@map("projects")
}

// ============================================
// Knowledge entry (per-project knowledge base)
// ============================================
model KnowledgeEntry {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  title     String
  content   String   @default("")
  tags      String   @default("")
  fileUrl   String?  @map("file_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([type])
  @@map("knowledge_entries")
}

// ============================================
// AI Usage Log — track every generation
// ============================================
model AIUsageLog {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String?  @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid
  operation   String   // generate_script | modify_script | generate_storyboard | modify_shot
  modelName   String   @map("model_name")
  tokensIn    Int      @default(0) @map("tokens_in")
  tokensOut   Int      @default(0) @map("tokens_out")
  cost        Float    @default(0) // estimated cost in USD
  createdAt   DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_usage_logs")
}

// ============================================
// Subscription & Quota
// ============================================
model Subscription {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @unique @map("workspace_id") @db.Uuid
  planTier        String   @default("free") @map("plan_tier") // free | pro | team | enterprise
  quotaTotal      Int      @default(10) @map("quota_total") // AI calls per month
  quotaUsed       Int      @default(0) @map("quota_used")
  quotaResetAt    DateTime @map("quota_reset_at")
  projectLimit    Int      @default(3) @map("project_limit")
  memberLimit     Int      @default(1) @map("member_limit")
  features        String   @default("") // JSON array of feature flags
  stripeCustomerId String?   @map("stripe_customer_id")
  stripeSubId     String?    @map("stripe_sub_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================
// Plan definitions (reference table)
// ============================================
model PlanDefinition {
  id            String  @id @default(uuid()) @db.Uuid
  tier          String  @unique // free | pro | team | enterprise
  name          String
  priceMonthly  Float   @default(0) @map("price_monthly")
  quotaTotal    Int     @default(10) @map("quota_total")
  projectLimit  Int     @default(3) @map("project_limit")
  memberLimit   Int     @default(1) @map("member_limit")
  modelAccess   String  @default("basic") @map("model_access") // basic | all | priority
  exportFormats String  @default("copy") @map("export_formats") // JSON: ["copy","excel","word","pdf"]
  features      String  @default("") @map("features_list")

  @@map("plan_definitions")
}
